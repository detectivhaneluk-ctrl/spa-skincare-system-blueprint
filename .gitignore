tmp-cookies*.txt
tmp-login*.html
handoff/verify-handoff-artifacts.failures.txt
vendor/
distribution/release-law/

# Source / handoff hygiene (must match handoff/HandoffZipRules.ps1; keep system/.env.example unignored)
# Local trees may keep .env and logs for runtime; they must not be treated as canonical handoff/source truth.
system/.env
system/.env.local
handoff/*.zip
**/*.zip
**/*.log

# PHP session files (keep directory via .gitkeep only)
system/storage/sessions/*
!system/storage/sessions/.gitkeep

# IDE / tooling noise (never canonical)
.cursor/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Keys and local Composer auth (never commit)
*.pem
*.p12
auth.json
id_rsa
*.key

# image-pipeline dependencies — install with npm ci in workers/image-pipeline (not canonical source)
workers/image-pipeline/node_modules/

# Accidental npm at repository root (do not commit)
/node_modules/

# Optional Playwright deps for system/scripts/dev-only/calendar_screenshot_once.mjs (npm install playwright)
system/scripts/dev-only/node_modules/
