# Copy to .env (see system/.gitignore — .env is not committed).
# Local dev: set APP_ENV=local and APP_DEBUG=true only on trusted machines.
# If your vhost DocumentRoot is the repository root (not system/public), use APP_ENV=local — root index.php refuses HTTP when APP_ENV is production|prod.
# Production: APP_DEBUG must remain false (HttpErrorHandler uses it to avoid leaking exceptions).

APP_ENV=production
APP_DEBUG=false
# When true, every HTTP request checks disk vs `migrations` table alignment; misalignment → 503 (off by default for local dev).
# MIGRATION_BASELINE_ENFORCE=false
APP_URL=http://localhost
APP_TIMEZONE=UTC
SESSION_LIFETIME=120
SESSION_COOKIE=spa_session
SESSION_SECURE=false
SESSION_DOMAIN=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_db_user
DB_PASSWORD=

# Optional: ext-redis + shared cache + sliding-window public abuse limits (booking/commerce/intake). Unset = MySQL abuse table + Noop in-process shared cache.
# REDIS_URL=redis://127.0.0.1:6379
# REDIS_KEY_PREFIX=spa

# Image pipeline — PHP upload gateway (foundation). See system/docs/IMAGE-PIPELINE-FOUNDATION-01-OPS.md
IMAGE_MAX_UPLOAD_MB=12
IMAGE_MAX_MEGAPIXELS=40

# Image pipeline — Node worker (optional; read by worker / run_media_image_worker_once.php via putenv)
IMAGE_JOB_STALE_LOCK_MINUTES=30
IMAGE_JOB_MAX_ATTEMPTS=5

# Local dev only: when APP_ENV=local, each successful media upload spawns a background PHP drain for that
# asset (FIFO-safe; no production queue change). Default ON for local; set 0/false to disable. Ignored when APP_ENV=production.
# If Apache reports PHP_BINARY as php-cgi.exe, set explicit CLI: MEDIA_DEV_PHP_BINARY=C:\path\to\php.exe
# MEDIA_DEV_AUTO_DRAIN_ON_UPLOAD=0
# NODE_BINARY=C:\path\to\node.exe
# (Optional but recommended on Windows if `node` is not on the service account PATH — forwarded to drain/worker children.)
